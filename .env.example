# ─────────────────────────────────────────────────────────────────────────────
# RMZ — environment variables. Copy to `.env.local` for dev; set the real values
# in your host (Vercel) project settings for production. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Long random string used to sign Payload auth tokens.
#   generate with:  openssl rand -hex 32
PAYLOAD_SECRET=

# Database connection.
#   • Local dev (SQLite, default):   file:./rmz.db
#   • Production (Postgres/Neon):     postgres://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URI=file:./rmz.db

# Admin panel path (default /studio). Pick a non-obvious one for prod.
PAYLOAD_ADMIN_PATH=/studio

# First-admin seed — used ONCE by `npm run seed` to create the initial admin.
# Use a strong password in prod; this account can manage everything.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Production media storage (Vercel Blob). Leave empty in local dev to use disk.
#   create in Vercel → Storage → Blob, then add the token here.
BLOB_READ_WRITE_TOKEN=
